# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Public site URL (Open Graph / Twitter image URLs, metadataBase). Use http://localhost:3000 for local OG previews.
NEXT_PUBLIC_SITE_URL=

# MySQL Database
MYSQL_HOST=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# Perscom API
PERSCOM_API_URL=
PERSCOM_API_KEY=
# Inbound webhook: set URL in Perscom to https://<your-domain>/api/perscom/webhook (POST). Secret from Integrations > Webhooks; verify via HMAC-SHA256 Signature header on raw body.
PERSCOM_WEBHOOK_SECRET=

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Oracle Cloud Infrastructure (OCI)
OCI_PROFILE_PAR_URL=
OCI_BACKGROUND_PAR_URL=
OCI_ENDPOINT=
OCI_BUCKET_NAME=
OCI_SECRET_ACCESS_KEY=
OCI_ACCESS_KEY_ID=
OCI_GALLERY_PAR_URL=
# Environment
NODE_ENV=
TZ=
